# ==================== DATABASE ====================
DATABASE_URL=postgresql+asyncpg://prestamos_user:prestamos_pass@localhost:5432/prestamos_db

# ==================== SECURITY ====================
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== ENVIRONMENT ====================
ENVIRONMENT=development
APP_URL=http://localhost:3000
API_URL=http://127.0.0.1:8000
ENABLE_STARTUP_SEED=false

# ==================== EMAIL (SMTP) ====================
SMTP_EMAIL=noreply@prestamos.local
SMTP_PASSWORD=

# ==================== SMS (TWILIO) ====================
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ==================== BRAINTREE (PAYMENTS) ====================
BRAINTREE_MERCHANT_ID=
BRAINTREE_PUBLIC_KEY=
BRAINTREE_PRIVATE_KEY=

# ==================== STORAGE ====================
STORAGE_BACKEND=r2
LOCAL_STORAGE_PATH=/app/uploads

# ==================== CLOUDFLARE R2 ====================
# Required
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=prestamos-prod

# ==================== OCR (PADDLEOCR) ====================
OCR_ENABLED=true
OCR_DEVICE=cpu
OCR_USE_ANGLE_CLS=true
OCR_LANG=es

# ==================== API ====================
API_TITLE=Plataforma de Préstamos
API_VERSION=0.1.0
API_DESCRIPTION=SaaS para gestión de préstamos con validación OCR

# ==================== CORS ====================
CORS_ORIGINS=["http://localhost:4321","http://127.0.0.1:4321","http://localhost:3000","http://127.0.0.1:3000","http://localhost:5173","http://127.0.0.1:5173"]
